---
import Logo from './Logo.astro';
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-400">
  <div class="max-w-[1200px] mx-auto px-8 h-16 flex items-center justify-between">
    <Logo />

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Principal">
      <a href="#como-funciona" class="text-[0.9375rem] text-[#0F3E17] opacity-75 hover:opacity-100 transition-opacity duration-300">Como funciona</a>
      <a href="#resultados" class="text-[0.9375rem] text-[#0F3E17] opacity-75 hover:opacity-100 transition-opacity duration-300">Resultados</a>
      <a href="#faq" class="text-[0.9375rem] text-[#0F3E17] opacity-75 hover:opacity-100 transition-opacity duration-300">FAQ</a>
    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-3">
      <a
        href="#cta-final"
        class="hidden md:inline-flex items-center px-5 py-2.5 bg-[#0F3E17] text-white text-sm font-medium rounded-[12px] hover:opacity-90 transition-opacity duration-300"
      >
        Agendar análise gratuita
      </a>
      <button
        id="menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-6 h-0.5 bg-[#0F3E17] transition-all duration-300"></span>
        <span class="block w-6 h-0.5 bg-[#0F3E17] transition-all duration-300"></span>
        <span class="block w-6 h-0.5 bg-[#0F3E17] transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-[#E5E7EB] px-6 py-6 flex-col gap-4"
    aria-label="Menu mobile"
  >
    <a href="#como-funciona" class="text-[#0F3E17] text-base font-medium py-2 border-b border-[#E5E7EB]">Como funciona</a>
    <a href="#resultados" class="text-[#0F3E17] text-base font-medium py-2 border-b border-[#E5E7EB]">Resultados</a>
    <a href="#faq" class="text-[#0F3E17] text-base font-medium py-2 border-b border-[#E5E7EB]">FAQ</a>
    <a
      href="#cta-final"
      class="inline-flex items-center justify-center px-5 py-3 bg-[#0F3E17] text-white text-sm font-medium rounded-[12px] mt-2"
    >
      Agendar análise gratuita
    </a>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-white', 'border-b', 'border-[#E5E7EB]', 'shadow-sm');
    } else {
      navbar.classList.remove('bg-white', 'border-b', 'border-[#E5E7EB]', 'shadow-sm');
    }
  });

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    if (isOpen) {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      menuBtn.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      menuBtn.setAttribute('aria-expanded', 'true');
    }
  });

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      menuBtn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
