---
const features = [
  {
    title: 'Agenda sempre cheia',
    text: 'Cancelamentos são preenchidos automaticamente pela lista de espera — sem nenhum esforço da equipe.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M8 14h.01M12 14h.01M16 14h.01"/></svg>`,
  },
  {
    title: 'Zero ligação para confirmar',
    text: 'WhatsApp confirma, lembra e reconfirma. A recepção só vê o que já está resolvido.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Pacientes que voltam',
    text: '+40% de taxa de retorno com follow-up automático pós-consulta e solicitação de agendamento.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
  {
    title: 'Reativação de inativos',
    text: 'O sistema identifica pacientes que sumiram e envia mensagens personalizadas no momento certo.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>`,
  },
  {
    title: 'Recepção focada',
    text: 'Tarefas repetitivas saem dos humanos. A equipe cuida do atendimento, não de lembretes.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'Relatório mensal',
    text: 'Confirmações, faltas, churn e receita recuperada — dados reais para decisões melhores.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  },
];
---
<section id="resultados" class="py-20 px-4 bg-[#FFFEFC]">
  <div class="max-w-[1200px] mx-auto">
    <h2 class="reveal text-[2rem] sm:text-[2.5rem] font-light text-[#0F3E17] mb-14">
      O que muda no dia a dia da sua clínica
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f, i) => (
        <div
          class="reveal-scale bg-white rounded-[16px] p-8 border border-[#E5E7EB] hover:border-[#B0D8B5] hover:shadow-[0_4px_24px_rgba(15,62,23,0.08)] transition-all duration-300"
          style={`transition-delay: ${i * 80}ms`}
        >
          <!-- Icon container (44x44 como no Figma) -->
          <div class="w-11 h-11 rounded-[10px] bg-[#E1F4DF] flex items-center justify-center text-[#0F3E17] mb-5" set:html={f.icon} />
          <!-- Accent line (1px, 4px alto, como no Figma) -->
          <div class="w-px h-1 bg-[#E1F4DF] mb-4"></div>
          <h3 class="text-[1.0625rem] font-medium text-[#0F3E17] mb-2">{f.title}</h3>
          <p class="text-[0.9rem] leading-[1.75] text-[rgba(15,62,23,0.65)]">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
