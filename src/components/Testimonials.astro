---
const testimonials = [
  {
    text: 'Reduziu nossas faltas em 80% no primeiro mês. Minha recepcionista agora tem tempo para atender bem os pacientes que chegam — em vez de ficar no telefone confirmando consulta.',
    name: 'Dr. Carlos Mendes',
    role: 'Ortopedista',
    location: 'São Paulo, SP',
    initials: 'CM',
  },
  {
    text: 'Antes eu passava horas ligando para confirmar consultas. Hoje o sistema faz tudo isso e eu só abro o painel para ver os números. Simples assim.',
    name: 'Dra. Ana Paula Costa',
    role: 'Dentista',
    location: 'Campinas, SP',
    initials: 'AC',
  },
  {
    text: 'Reativamos 34 pacientes inativos em 60 dias. São pessoas que já nos conheciam e voltaram sem nenhuma campanha de marketing. Foi surpreendente.',
    name: 'Dr. Rafael Lima',
    role: 'Clínica Multidisciplinar',
    location: 'Belo Horizonte, MG',
    initials: 'RL',
  },
];
---
<section class="py-20 px-4 bg-[#F8FAF8]">
  <div class="max-w-[1200px] mx-auto">
    <div class="max-w-[560px] mb-12">
      <div class="reveal inline-flex items-center px-3 py-1.5 rounded-full bg-[#E1F4DF] mb-5">
        <span class="text-[0.75rem] font-semibold tracking-[0.08em] uppercase text-[#0F3E17]">Depoimentos</span>
      </div>
      <h2 class="reveal reveal-delay-1 text-[2rem] sm:text-[2.5rem] font-light text-[#0F3E17] mb-3">
        O que dizem nossas clínicas
      </h2>
      <p class="reveal reveal-delay-2 text-[0.9375rem] leading-[1.8] text-[rgba(15,62,23,0.60)]">
        Resultados reais de clínicas que implementaram o sistema nos últimos 12 meses.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="reveal-scale bg-white rounded-[16px] p-8 border border-[#E5E7EB] flex flex-col"
          style={`transition-delay: ${i * 100}ms`}
        >
          <span class="text-[4.5rem] leading-none text-[#E1F4DF] font-serif mb-4 select-none" aria-hidden="true">&ldquo;</span>
          <p class="text-[0.9375rem] italic leading-[1.8] text-[#0F3E17] flex-1 mb-6">{t.text}</p>
          <div class="border-t border-[#E5E7EB] pt-6 flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-[#E1F4DF] flex items-center justify-center text-[#0F3E17] text-sm font-semibold flex-shrink-0" aria-hidden="true">
              {t.initials}
            </div>
            <div>
              <p class="text-[0.9rem] font-medium text-[#0F3E17]">{t.name}</p>
              <p class="text-[0.8125rem] text-[rgba(15,62,23,0.55)]">{t.role} · {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
